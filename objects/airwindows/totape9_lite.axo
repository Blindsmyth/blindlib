    for (x = ik_spacing * 2; x >= 0; x--) if (finalSlew_q < slewClipR[x]) finalSlew_q = slewClipR[x];
  }
  {
    int32_t den = AW_Q27 + aw_smul2731(finalSlew_q, clip_post_mul_q31);
    if (den < 1) den = 1;
    int32_t postclip_q = (int32_t)(((int64_t)clip_post_nom_q27 * (int64_t)AW_Q27) / (int64_t)den);
    if (xRq > postclip_q) xRq = postclip_q;
    if (xRq < -postclip_q) xRq = -postclip_q;
  }
}

fpdL ^= fpdL << 13; fpdL ^= fpdL >> 17; fpdL ^= fpdL << 5;
fpdR ^= fpdR << 13; fpdR ^= fpdR >> 17; fpdR ^= fpdR << 5;

outlet_outL = __SSAT(xLq, 28);
outlet_outR = __SSAT(xRq, 28);
}
]]></code.srate>
   </obj.normal>
</objdefs>
