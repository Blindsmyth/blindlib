<objdefs appVersion="1.1.0">
   <obj.normal id="bool param get pulse bi" uuid="5224773f-18de-4231-8f92-b1f22bb953D2">
      <sDescription>Read sketchy_params cell; emits plus/minus one-k-period pulses when the stored signed counter changes (MODE_BOOL_PULSE_BI).</sDescription>
      <author>AI Assistant / Simon</author>
      <license>GPL</license>
      <inlets/>
      <outlets>
         <bool32.pulse name="plus" description="High one k-period when value increases"/>
         <bool32.pulse name="minus" description="High one k-period when value decreases"/>
         <int32 name="v002" description="Object version (incremented each release)"/>
      </outlets>
      <displays/>
      <params/>
      <attribs>
         <spinner name="page" description="page index" MinValue="-127" MaxValue="127" DefaultValue="0"/>
         <spinner name="param" description="parameter index (0-7)" MinValue="0" MaxValue="7" DefaultValue="0"/>
      </attribs>
      <code.declaration><![CDATA[rootc::objectinstance_sketchy__params* param_table;
int32_t prevValue;]]></code.declaration>
      <code.init><![CDATA[param_table = &parent->objectinstance_sketchy__params_i;
prevValue = param_table->array[attr_page][attr_param];]]></code.init>
      <code.krate><![CDATA[int32_t v = param_table->array[attr_page][attr_param];
outlet_plus = (v > prevValue);
outlet_minus = (v < prevValue);
prevValue = v;
outlet_v002 = 2;]]></code.krate>
   </obj.normal>
</objdefs>
